import json
from typing import Any, List, Dict
from datamodel import Listing, Observation, Order, OrderDepth, ProsperityEncoder, Symbol, Trade, TradingState

class Logger:
    def __init__(self) -> None:
        self.logs = ""
        self.max_log_length = 3750

    def print(self, *objects: Any, sep: str = " ", end: str = "\n") -> None:
        self.logs += sep.join(map(str, objects)) + end

    def flush(self, state: TradingState, orders: dict[Symbol, list[Order]], conversions: int, trader_data: str) -> None:
        base_length = len(self.to_json([self.compress_state(state, ""), self.compress_orders(orders), conversions, "", ""]))
        max_item_length = (self.max_log_length - base_length) // 3
        print(self.to_json([
            self.compress_state(state, self.truncate(state.traderData, max_item_length)),
            self.compress_orders(orders),
            conversions,
            self.truncate(trader_data, max_item_length),
            self.truncate(self.logs, max_item_length),
        ]))
        self.logs = ""

    def compress_state(self, state: TradingState, trader_data: str) -> list[Any]:
        return [state.timestamp, trader_data, self.compress_listings(state.listings), self.compress_order_depths(state.order_depths), self.compress_trades(state.own_trades), self.compress_trades(state.market_trades), state.position, self.compress_observations(state.observations)]

    def compress_listings(self, listings: dict[Symbol, Listing]) -> list[list[Any]]:
        return [[l.symbol, l.product, l.denomination] for l in listings.values()]

    def compress_order_depths(self, order_depths: dict[Symbol, OrderDepth]) -> dict[Symbol, list[Any]]:
        return {s: [d.buy_orders, d.sell_orders] for s, d in order_depths.items()}

    def compress_trades(self, trades: dict[Symbol, list[Trade]]) -> list[list[Any]]:
        compressed = []
        for arr in trades.values():
            for t in arr:
                compressed.append([t.symbol, t.price, t.quantity, t.buyer, t.seller, t.timestamp])
        return compressed

    def compress_observations(self, observations: Observation) -> list[Any]:
        obs = {p: [o.bidPrice, o.askPrice, o.transportFees, o.exportTariff, o.importTariff, o.sugarPrice, o.sunlightIndex] 
               for p, o in observations.conversionObservations.items()}
        return [observations.plainValueObservations, obs]

    def compress_orders(self, orders: dict[Symbol, list[Order]]) -> list[list[Any]]:
        compressed = []
        for arr in orders.values():
            for o in arr:
                compressed.append([o.symbol, o.price, o.quantity])
        return compressed

    def to_json(self, value: Any) -> str:
        return json.dumps(value, cls=ProsperityEncoder, separators=(",", ":"))

    def truncate(self, value: str, max_length: int) -> str:
        if len(json.dumps(value)) <= max_length: return value
        return value[:max_length-3] + "..."

logger = Logger()

class Trader:
    def run(self, state: TradingState) -> tuple[dict[Symbol, list[Order]], int, str]:
        result = {}
        conversions = 0
        LIMIT = 80 # Position limit for Round 1
        
        trader_dict = {"PEPPER_HISTORY": [], "OSMIUM_HISTORY": []}
        if state.traderData:
            try:
                trader_dict = json.loads(state.traderData)
            except:
                pass

        for product in ["INTARIAN_PEPPER_ROOT", "ASH_COATED_OSMIUM"]:
            depth: OrderDepth = state.order_depths.get(product)
            if not depth: continue
                
            orders: List[Order] = []
            pos = state.position.get(product, 0)
            
            # 1. VWMP Calculation to mitigate low-volume price noise
            best_ask = min(depth.sell_orders.keys()) if depth.sell_orders else None
            best_bid = max(depth.buy_orders.keys()) if depth.buy_orders else None
            
            if not (best_ask and best_bid): continue

            ask_vol = abs(depth.sell_orders[best_ask])
            bid_vol = depth.buy_orders[best_bid]
            mid_price = ((best_bid * ask_vol) + (best_ask * bid_vol)) / (ask_vol + bid_vol)
            
            # 2. Dynamic SMA Windows
            history_key = "PEPPER_HISTORY" if product == "INTARIAN_PEPPER_ROOT" else "OSMIUM_HISTORY"
            history = trader_dict.get(history_key, [])
            history.append(mid_price)
            
            # Faster window for Pepper (trend following), slower for Osmium (burst filtering)
            window = 15 if product == "INTARIAN_PEPPER_ROOT" else 30
            if len(history) > window: history.pop(0)
            trader_dict[history_key] = history
            
            if len(history) >= 10:
                sma = sum(history) / len(history)
                
                # Sanity check for Osmium mean-reversion
                if product == "ASH_COATED_OSMIUM" and abs(sma - 10000) > 15:
                    sma = 10000
                
                # 3. Asymmetric Scaling and Thresholds
                # Shift risk_offset to aggressively shed positions near limits
                risk_offset = (pos / LIMIT) * 2.0 
                
                # Tighter edges to resolve P&L plateaus
                edge = 1.5 if product == "INTARIAN_PEPPER_ROOT" else 4.0
                
                # Asymmetric bias for Pepper Root to favor longs in an uptrend
                buy_bias = -0.5 if product == "INTARIAN_PEPPER_ROOT" else 0.0
                
                buy_thr = sma - edge - risk_offset + buy_bias
                sell_thr = sma + edge - risk_offset

                # 4. Aggressive Market Taking
                for price, vol in sorted(depth.sell_orders.items()):
                    if price <= buy_thr and pos < LIMIT:
                        # Take full available volume if it beats our threshold
                        buy_qty = min(abs(vol), LIMIT - pos)
                        orders.append(Order(product, int(price), int(buy_qty)))
                        pos += buy_qty
                            
                for price, vol in sorted(depth.buy_orders.items(), reverse=True):
                    if price >= sell_thr and pos > -LIMIT:
                        sell_qty = min(abs(vol), pos + LIMIT)
                        orders.append(Order(product, int(price), int(-sell_qty)))
                        pos -= sell_qty

                # 5. Dynamic Market Making (Pennying)
                if pos < LIMIT:
                    mm_buy = min(best_bid + 1, int(sma - 1))
                    orders.append(Order(product, mm_buy, LIMIT - pos))
                if pos > -LIMIT:
                    mm_sell = max(best_ask - 1, int(sma + 1))
                    orders.append(Order(product, mm_sell, -LIMIT - pos))

            result[product] = orders

        td_out = json.dumps(trader_dict)
        logger.flush(state, result, conversions, td_out)
        return result, conversions, td_out
